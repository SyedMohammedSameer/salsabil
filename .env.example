# ─── Supabase ────────────────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# ─── Groq (V1 AI) ────────────────────────────────────────────────────────────
GROQ_API_KEY=gsk_your-groq-key

# ─── Anthropic Claude (V2 AI — server-side only, never VITE_ prefix) ─────────
ANTHROPIC_API_KEY=sk-ant-your-key

# ─── Web Push VAPID (for push notifications) ─────────────────────────────────
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_SUBJECT=mailto:hello@salsabil.app

# ─── Netlify dev ─────────────────────────────────────────────────────────────
# Copy this file to .env and fill in real values.
# NEVER commit .env — it is in .gitignore.
# ANTHROPIC_API_KEY and GROQ_API_KEY are server-side only — no VITE_ prefix.
