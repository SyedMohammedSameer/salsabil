# ─── Supabase ────────────────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# ─── OpenRouter (V1 AI — server-side only, never VITE_ prefix) ───────────────
# Get your free key at: https://openrouter.ai/keys
# Model used: meta-llama/llama-3.3-70b-instruct:free (strictly free tier)
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# ─── Anthropic Claude (V2 AI — server-side only, never VITE_ prefix) ─────────
ANTHROPIC_API_KEY=sk-ant-your-key

# ─── Web Push VAPID (for push notifications) ─────────────────────────────────
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_SUBJECT=mailto:hello@salsabil.app

# ─── Local dev instructions ───────────────────────────────────────────────────
# 1. cp .env.example .env
# 2. Fill in VITE_SUPABASE_URL, VITE_SUPABASE_ANON_KEY, OPENROUTER_API_KEY
# 3. npm run dev         ← starts Netlify dev (frontend + functions)
# NEVER commit .env — it is already in .gitignore.
# OPENROUTER_API_KEY and ANTHROPIC_API_KEY are server-side only — no VITE_ prefix.
