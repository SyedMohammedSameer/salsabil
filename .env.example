# ─── Supabase ────────────────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Service role key — server-side only (netlify functions), NEVER prefix with VITE_
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── OpenRouter (AI — server-side only, never VITE_ prefix) ──────────────────
# Get your free key at: https://openrouter.ai/keys
# Model used: meta-llama/llama-3.1-8b-instruct:free (strictly free tier)
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# ─── Web Push VAPID (for push notifications) ─────────────────────────────────
# Generate these once with: node scripts/generate-vapid.js
# VAPID_PUBLIC_KEY and VAPID_PRIVATE_KEY are server-side only (netlify functions)
# VITE_VAPID_PUBLIC_KEY is the same public key exposed to the browser (safe to expose)
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VITE_VAPID_PUBLIC_KEY=your-vapid-public-key

# ─── Local dev instructions ───────────────────────────────────────────────────
# 1. cp .env.example .env
# 2. Fill in Supabase values from: Supabase Dashboard → Settings → API
# 3. Add your OpenRouter key from: https://openrouter.ai/keys
# 4. Generate VAPID keys: node scripts/generate-vapid.js
#    Copy the output into VAPID_PUBLIC_KEY, VAPID_PRIVATE_KEY, VITE_VAPID_PUBLIC_KEY
# 5. Run all SQL migrations in Supabase: Dashboard → SQL Editor → paste each file
#    supabase/migrations/0001_initial_schema.sql
#    supabase/migrations/0002_study_rooms.sql
#    supabase/migrations/0003_coins_and_garden.sql
#    supabase/migrations/0004_push_subscriptions.sql
# 6. Enable Realtime in Supabase Dashboard → Database → Replication:
#    study_rooms, room_participants, room_messages, notifications
# 7. npm run dev   ← starts Netlify dev (frontend + functions together)
#
# NEVER commit .env — it is already in .gitignore.
# OPENROUTER_API_KEY, VAPID_PRIVATE_KEY, SUPABASE_SERVICE_ROLE_KEY = server-side only.
