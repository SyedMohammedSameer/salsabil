rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===========================
    // SECURITY: NO CATCH-ALL RULE
    // Each collection must have explicit rules
    // ===========================

    // GARDEN MODULE: Study Rooms and participants
    match /studyRooms/{roomId} {
      // Allow authenticated users to read all study rooms
      allow read: if request.auth != null;

      // Allow authenticated users to create study rooms
      allow create: if request.auth != null
        && request.auth.uid == resource.data.createdBy;

      // Allow room creator and participants to update room
      allow update: if request.auth != null
        && (request.auth.uid == resource.data.createdBy
            || exists(/databases/$(database)/documents/studyRooms/$(roomId)/participants/$(request.auth.uid)));

      // Allow room creator to delete room
      allow delete: if request.auth != null
        && request.auth.uid == resource.data.createdBy;

      // Participants subcollection
      match /participants/{participantId} {
        // Allow authenticated users to read participants
        allow read: if request.auth != null;

        // Allow users to create/update their own participant document
        allow create, update: if request.auth != null
          && request.auth.uid == participantId;

        // Allow room owner and the participant themselves to delete
        allow delete: if request.auth != null
          && (request.auth.uid == participantId
              || request.auth.uid == get(/databases/$(database)/documents/studyRooms/$(roomId)).data.createdBy);
      }
    }

    // Personal user data collections
    match /users/{userId} {
      // Users can only access their own data
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // Personal gardens subcollection
      match /personalGarden/{treeId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Garden trees subcollection
      match /garden/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Personal tasks subcollection
      match /tasks/{taskId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Focus sessions / Pomodoro sessions subcollection
      match /focusSessions/{sessionId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      match /pomodoroSessions/{sessionId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Prayer logs subcollection
      match /prayerLogs/{logId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Quran logs subcollection
      match /quranLogs/{logId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Notifications subcollection
      match /notifications/{notificationId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Settings subcollection
      match /settings/{settingId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // AI Profile (NEW)
      match /ai_profile/{profileId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // AI Interactions (NEW)
      match /ai_interactions/{interactionId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // AI Assistant chat history
      match /ai-assistant/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Workouts (nested under users)
      match /workouts/{entryId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Challenges (nested under users)
      match /challenges/{challengeId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Challenge days (nested under users)
      match /challenge_days/{dayId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // AI threads (nested under users)
      match /ai_threads/{threadId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Workouts collection structure: workouts/{userId}/entries/{entryId}
    match /workouts/{userId} {
      match /entries/{entryId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Challenges collection structure: challenges/{userId}/items/{challengeId}
    match /challenges/{userId} {
      match /items/{challengeId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Challenge days collection structure: challenge_days/{userId}/days/{dayId}
    match /challenge_days/{userId} {
      match /days/{dayId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // AI threads collection structure: ai_threads/{userId}/threads/{threadId}
    match /ai_threads/{userId} {
      match /threads/{threadId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Root-level settings (legacy, prefer users/{userId}/settings)
    match /settings/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // User settings collection (used by firebaseService.ts)
    match /user_settings/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Push notification tokens
    match /push_tokens/{userId} {
      match /tokens/{tokenId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Root-level notifications (legacy, prefer users/{userId}/notifications)
    // Allow list queries filtering by uid
    match /notifications/{notificationId} {
      // Allow reads if the notification belongs to the authenticated user
      // For list queries, Firestore ensures the where clause matches
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.uid == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.uid == request.auth.uid;
    }

    // Prevent access to any other collections not explicitly defined
    // This ensures security by default
  }
}